APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Groq API — получить на https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

AI_SERVICE_URL=http://ai-service:8001

# ── JWT ──────────────────────────────────────────────────────────────────────
# Длинная случайная строка. Сгенерить:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# В APP_ENV=production дефолтное значение запрещено (см. app/config.py).
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Список origin'ов через запятую, откуда браузер может стучать на API.
# Пример (dev):    CORS_ORIGINS=http://localhost:3000
# Пример (prod):   CORS_ORIGINS=https://support.acme.com,https://admin.acme.com
# Пустая строка — CORS отключён (ок если фронта ещё нет).
# "*" НЕ ПОДДЕРЖИВАЕТСЯ — это дыра в безопасности.
CORS_ORIGINS=

# ── Bootstrap-admin ──────────────────────────────────────────────────────────
# Первый пользователь с этим email, который зарегистрируется через
# POST /auth/register, автоматически получит role=admin.
# Решает "курицу-яйцо": без этого первого админа негде взять.
# Если переменная пустая — никто не становится админом при регистрации.
# После того как первый админ создан, переменную можно убрать из .env.
BOOTSTRAP_ADMIN_EMAIL=
